{
  "name": "sipkpfi-automation-test",
  "version": "1.0.0",
  "description": "Automation testing untuk SIPKPFI menggunakan Cypress",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "test:headless": "cypress run",
    "test:chrome": "cypress run --browser chrome",
    "test:firefox": "cypress run --browser firefox",
    "test:edge": "cypress run --browser edge",
    "test:login": "cypress run --spec 'cypress/e2e/login.cy.js'",
    "test:loan": "cypress run --spec 'cypress/e2e/loanApplication.cy.js'",
    "test:report": "cypress run && npm run report:merge && npm run report:generate",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "clean:reports": "rm -rf cypress/reports cypress/videos cypress/screenshots",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/merged-report.json",
    "report:generate": "marge cypress/reports/merged-report.json -f report -o cypress/reports/html",
    "report:open": "open cypress/reports/html/report.html"
  },
  "keywords": [
    "cypress",
    "testing",
    "automation",
    "e2e"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.6.0",
    "cypress-mochawesome-reporter": "^3.8.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
